#!/bin/bash
# Auto-regenerate plugins.lock if any locked file changed
LOCK_SCRIPT="scripts/lock.py"
if [ ! -f "$LOCK_SCRIPT" ]; then
    exit 0
fi

# Check if any locked files are staged
LOCKED_FILES=$(python "$LOCK_SCRIPT" --list 2>/dev/null)
if [ -z "$LOCKED_FILES" ]; then
    exit 0
fi

NEED_REGEN=0
for f in $LOCKED_FILES; do
    if git diff --cached --name-only | grep -q "^$f$"; then
        NEED_REGEN=1
        break
    fi
done

if [ "$NEED_REGEN" -eq 1 ]; then
    echo "  pre-commit: regenerating plugins.lock..."
    python "$LOCK_SCRIPT"
    git add plugins.lock
fi
